# Postmark
POSTMARK_SERVER_TOKEN=xxx

# Business config
HOLD_TTL_SECONDS=300
WAITING_ROOM_CAP=50
AUTO_REFUND_WINDOW_HOURS=48
SERVICE_FEE_FLAT=500
TRANSFER_FEE_FLAT=500
