# Server
PORT=8810
NODE_ENV=development

# Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ticketer

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me
JWT_EXPIRES_IN=1h

# Paystack
